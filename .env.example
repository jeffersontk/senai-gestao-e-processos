# Supabase com Prisma.
# O projeto nao usa fallback local.

# App state salvo no banco.
SUPABASE_STATE_ID=gestao-horas

# Senha de login usada pela API interna enquanto o projeto nao usa Supabase Auth.
APP_LOGIN_PASSWORD="<defina-uma-senha-forte>"

# Opcional: dados do usuario root criado por `npm run seed:root`.
ROOT_USER_ID="root"
ROOT_USER_NAME="Root do Sistema"
ROOT_USER_EMAIL="admin@sistema.local"
ROOT_USER_CARGO="Administrador do sistema"
ROOT_USER_PASSWORD="<senha-inicial-do-root>"

# Supabase Postgres transaction pooler, usado pela aplicacao.
DATABASE_URL="postgresql://postgres.<project-ref>:<database-password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres session pooler, usado pelas migrations do Prisma.
DIRECT_URL="postgresql://postgres.<project-ref>:<database-password>@<region>.pooler.supabase.com:5432/postgres"

# Opcional se depois voce usar Supabase Auth no cliente.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="<publishable-key>"
